@baseUrl = http://localhost:3000
@contentType = application/json

# Nach dem Login-Request hier den erhaltenen Token eintragen:
@token = PASTE_TOKEN_HERE


### ============================================================
### AUTH
### ============================================================

### Register
POST {{baseUrl}}/auth/register
Content-Type: {{contentType}}

{"email": "test@test.de", "password": "geheim"}

###

### Login (Token aus Response kopieren und oben in @token eintragen)
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{"email": "test@test.de", "password": "geheim"}


### ============================================================
### GOALS
### ============================================================

### Alle Goals abrufen
GET {{baseUrl}}/goals
Authorization: Bearer {{token}}

###

### Goal erstellen
# @name createGoal
POST {{baseUrl}}/goals
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "title": "JavaScript lernen",
  "targetHours": 20.0,
  "startDate": "2026-06-01",
  "endDate": "2026-08-31"
}

###

### Goal aktualisieren (ID anpassen)
PUT {{baseUrl}}/goals/1
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "title": "JavaScript & TypeScript lernen",
  "targetHours": 30.0
}

###

### Goal-Status aktualisieren (ID anpassen)
PATCH {{baseUrl}}/goals/1/status
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{"status": "in_progress"}

###

### Goal löschen (ID anpassen)
DELETE {{baseUrl}}/goals/1
Authorization: Bearer {{token}}


### ============================================================
### PLANS
### ============================================================

### Alle Plans abrufen
GET {{baseUrl}}/plans
Authorization: Bearer {{token}}

###

### Plan erstellen
POST {{baseUrl}}/plans
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "title": "Lernplan Juni",
  "startDate": "2026-06-01",
  "endDate": "2026-06-30"
}

###

### Monatliche Plans abrufen (Format: YYYY-MM)
GET {{baseUrl}}/plans/monthly/2026-06
Authorization: Bearer {{token}}

###

### Plan aktualisieren (ID anpassen)
PUT {{baseUrl}}/plans/1
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "title": "Lernplan Juni – überarbeitet",
  "endDate": "2026-07-15"
}

###

### Plan löschen (ID anpassen)
DELETE {{baseUrl}}/plans/1
Authorization: Bearer {{token}}


### ============================================================
### SESSIONS
### ============================================================

### Alle Sessions abrufen
GET {{baseUrl}}/sessions
Authorization: Bearer {{token}}

###

### Session starten
POST {{baseUrl}}/sessions/start
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "topic": "Express Middleware",
  "goalId": 1
}

###

### Session stoppen (ID anpassen)
PATCH {{baseUrl}}/sessions/1/stop
Authorization: Bearer {{token}}


### ============================================================
### REMINDERS
### ============================================================

### Alle Reminders abrufen
GET {{baseUrl}}/reminders
Authorization: Bearer {{token}}

###

### Reminder erstellen
POST {{baseUrl}}/reminders
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
  "message": "Heute noch eine Lerneinheit einplanen!",
  "scheduledAt": "2026-06-24T09:00:00.000Z"
}


### ============================================================
### DASHBOARD
### ============================================================

### Dashboard-Daten abrufen
GET {{baseUrl}}/dashboard
Authorization: Bearer {{token}}
